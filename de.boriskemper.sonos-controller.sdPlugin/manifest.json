{
	"Name": "SONOS-Controller",
	"Version": "0.2.1.0",
	"Author": "Boris Kemper",
	"Actions": [
		{
			"Name": "Play Key",
			"UUID": "de.boriskemper.sonos-controller.sonos-toggle-play",
			"Icon": "imgs/actions/sonos-toggle-play/icon",
			"Tooltip": "Play Key with cover art and title animation.",
			"PropertyInspectorPath": "ui/sonos-toggle-play.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/sonos-toggle-play/icon"
				}
			]
		},
		{
			"Name": "Play Favorite",
			"UUID": "de.boriskemper.sonos-controller.play-favorite",
			"Icon": "imgs/actions/sonos-play-favorite/icon",
			"Tooltip": "Plays a selected SONOS favorite.",
			"PropertyInspectorPath": "ui/sonos-play-favorite.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/sonos-play-favorite/icon"
				}
			]
		},
		{
			"Name": "Playback Control",
			"UUID": "de.boriskemper.sonos-controller.sonos-playback-control",
			"Icon": "imgs/actions/sonos-playback-control/icon",
			"Tooltip": "Provides playback controls like next, previous, etc.",
			"PropertyInspectorPath": "ui/sonos-playback-control.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/sonos-playback-control/icon"
				}
			]
		},
		{
			"Name": "Volume Control",
			"UUID": "de.boriskemper.sonos-controller.sonos-key-volume",
			"Icon": "imgs/actions/sonos-key-volume/icon",
			"Tooltip": "Control SONOS volume with a key.",
			"PropertyInspectorPath": "ui/sonos-key-volume.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Name": "Unmuted",
					"Image": "imgs/actions/sonos-key-volume/icon"
				},
				{
					"Name": "Muted",
					"Image": "imgs/actions/sonos-key-volume/icon-muted"
				}
			]
		},
		{
			"Name": "Volume",
			"UUID": "de.boriskemper.sonos-controller.sonos-dial-volume",
			"Icon": "imgs/actions/sonos-dial-volume/icon",
			"Tooltip": "Control SONOS volume with a dial.",
			"PropertyInspectorPath": "ui/sonos-dial-volume.html",
			"Controllers": [
				"Encoder"
			],
			"Encoder": {
				"layout": "$A0",
				"TriggerDescription": {
					"Push": "Mute",
					"Rotate": "Adjust Volume",
					"Touch": "Preset Volume"
				}
			},
			"States": [
				{
					"Image": "imgs/actions/sonos-dial-volume/icon"
				}
			]
		},
		{
			"Name": "Favorites Dial",
			"UUID": "de.boriskemper.sonos-controller.sonos-dial-favorites",
			"Icon": "imgs/actions/sonos-dial-favorites/icon",
			"Tooltip": "Browse and play your personal Sonos favorites list.",
			"PropertyInspectorPath": "ui/sonos-dial-favorites.html",
			"Controllers": [
				"Encoder"
			],
			"Encoder": {
				"layout": "$A0",
				"TriggerDescription": {
					"Push": "Play selected favorite",
					"Rotate": "Browse favorites list",
					"Touch": "Return to now playing"
				}
			},
			"States": [
				{
					"Image": "imgs/actions/sonos-dial-favorites/icon"
				}
			]
		},
		{
			"Name": "Panorama Particles",
			"UUID": "de.boriskemper.sonos-controller.sonos-dial-particles",
			"Icon": "imgs/actions/sonos-dial-particles/icon",
			"Tooltip": "Particle animation spanning up to 4 LCD panels as one continuous scene.",
			"PropertyInspectorPath": "ui/sonos-dial-particles.html",
			"Controllers": [
				"Encoder"
			],
			"Encoder": {
				"layout": "$A0",
				"TriggerDescription": {
					"Push": "Toggle particle count / speed mode",
					"Rotate": "Adjust particle count or speed",
					"Touch": "None"
				}
			},
			"States": [
				{
					"Image": "imgs/actions/sonos-dial-particles/icon"
				}
			]
		},
		{
			"Name": "Track Dial",
			"UUID": "de.boriskemper.sonos-controller.sonos-dial-track",
			"Icon": "imgs/actions/sonos-dial-track/icon",
			"Tooltip": "Displays current track info and controls volume.",
			"PropertyInspectorPath": "ui/sonos-dial-track.html",
			"Controllers": [
				"Encoder"
			],
			"Encoder": {
				"layout": "$A0",
				"TriggerDescription": {
					"Push": "Skip to next track",
					"Rotate": "Seek ±5% in track",
					"Touch": "Toggle Play/Pause"
				}
			},
			"States": [
				{
					"Image": "imgs/actions/sonos-dial-track/icon"
				}
			]
		}
	],
	"Category": "SONOS-Controller",
	"CategoryIcon": "imgs/plugin/lobster",
	"CodePath": "bin/plugin.js",
	"Description": "Control your SONOS system with your StreamDeck+\nThis plugin is not connected to SONOS.\n\nThis plugin uses SONOS-TS by Stephan van Rooij (https://sonos-ts.svrooij.io/), licensed under MIT License.\n\nIcons by\nhttps://pictogrammers.com\n\nsdpi-components by GeekyEggo\nhttps://github.com/geekyeggo/sdpi-components",
	"Icon": "imgs/plugin/lobster",
	"SDKVersion": 3,
	"Software": {
		"MinimumVersion": "6.9"
	},
	"OS": [
		{
			"Platform": "mac",
			"MinimumVersion": "10.15"
		},
		{
			"Platform": "windows",
			"MinimumVersion": "10"
		}
	],
	"Nodejs": {
		"Version": "20",
		"Debug": "enabled"
	},
	"UUID": "de.boriskemper.sonos-controller"
}